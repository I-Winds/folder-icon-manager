<Window x:Class="FolderIconManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Icon Manager"
        Width="1180"
        MinWidth="960"
        Height="760"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">
    <Grid Background="{StaticResource CanvasBrush}">
        <Border Margin="18" Padding="22" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="FavoriteSidebarColumn" Width="220" />
                    <ColumnDefinition x:Name="FavoriteSidebarGap" Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="FavoriteDropZone" Grid.Column="0" Background="{StaticResource DropZoneBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" AllowDrop="True" PreviewDragEnter="FavoriteDropZone_PreviewDragEnter" PreviewDragOver="FavoriteDropZone_PreviewDragOver" PreviewDragLeave="FavoriteDropZone_PreviewDragLeave" Drop="FavoriteDropZone_Drop">
                    <Grid>
                        <Grid x:Name="FavoriteSidebarContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="46" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="230" />
                            </Grid.RowDefinitions>
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="图标收藏栏" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Style="{StaticResource FavoriteLibraryButtonStyle}" ToolTip="添加收藏夹" Click="AddFavorite_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="+" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" /><TextBlock Margin="6,0,0,0" Text="添加图标库" VerticalAlignment="Center" /></StackPanel>
                                </Button>
                            </Grid>
                            <Border Grid.Row="1" Background="{StaticResource BorderBrush}" />
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding FavoriteFolders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Expanded="FavoriteFolderExpander_Expanded" Collapsed="FavoriteFolderExpander_Collapsed">
                                                <Expander.Header>
                                                    <Grid Margin="10,8">
                                                        <Grid.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"><MenuItem Header="从收藏夹移除" CommandParameter="{Binding}" Click="RemoveFavoriteFolder_Click" /></ContextMenu>
                                                        </Grid.ContextMenu>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" FontSize="17" Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Grid.Column="2" Text="{Binding DisplayName}" ToolTip="{Binding FolderPath}" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </Expander.Header>
                                                <ListBox ItemsSource="{Binding Icons}" SelectedItem="{Binding DataContext.SelectedFavoriteIcon, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" MouseDoubleClick="FavoriteIcons_MouseDoubleClick" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="0" />
                                                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="ItemBorder" Margin="10,1" Padding="6,5" Background="Transparent" BorderBrush="Transparent" BorderThickness="3,0,0,0"><ContentPresenter /></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#E8F2FC" /><Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Image Source="{Binding ThumbnailPreview}" Width="28" Height="28" Stretch="Uniform" /><TextBlock Grid.Column="2" Text="{Binding FileName}" ToolTip="{Binding IconPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" /></Grid></DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Border Grid.Row="3" Background="{StaticResource BorderBrush}" />
                            <Grid Grid.Row="4" Margin="14,12">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="6" /><RowDefinition Height="*" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="ICO预览" FontWeight="SemiBold" /><Button Grid.Column="1" Style="{StaticResource RoundIconButtonStyle}" ToolTip="在资源管理器中打开" IsEnabled="{Binding CanOpenCurrentPreviewIcon}" Click="OpenCurrentPreviewIconLocation_Click"><TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE838;" FontSize="14" /></Button></Grid>
                                <Border Grid.Row="2" Width="90" Height="90" HorizontalAlignment="Center" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"><Grid><Image Source="{Binding CurrentPreviewIcon.OriginalPreview}" Width="64" Height="64" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" /><TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEB9F;" FontSize="34" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding CurrentPreviewIcon.OriginalPreview}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Grid></Border>
                                <TextBlock Grid.Row="4" Text="{Binding FavoritePreviewDescription}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="FavoriteSidebarHandle" Grid.Column="1" Cursor="Hand" ToolTip="收起图标收藏" CornerRadius="0,6,6,0" PreviewMouseLeftButtonUp="FavoriteSidebarHandle_PreviewMouseLeftButtonUp">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#EFF4F8" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C8E1F8" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Path x:Name="FavoriteSidebarChevron" Data="M 5,10 L 2,14 L 5,18 Z" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{StaticResource MutedTextBrush}" />
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="16" /><RowDefinition Height="Auto" /><RowDefinition Height="16" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="8" /><RowDefinition Height="0.81*" /><RowDefinition Height="0.19*" /></Grid.RowDefinitions>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="0.05*" /><ColumnDefinition Width="0.45*" /><ColumnDefinition Width="20" /><ColumnDefinition Width="0.45*" /><ColumnDefinition Width="0.05*" /></Grid.ColumnDefinitions>
                        <Border x:Name="NewTargetFolderDropZone" Grid.Column="1" Padding="18" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDragEnter="DropZone_PreviewDragEnter" PreviewDragOver="DropZone_PreviewDragOver" PreviewDragLeave="DropZone_PreviewDragLeave" Drop="TargetFolderDropZone_Drop">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="10" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="请选择目标文件夹" FontSize="16" FontWeight="SemiBold" /><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Style="{StaticResource RevealActionButtonStyle}" Width="30" MinWidth="0" Height="30" Padding="0" ToolTip="看看替换效果" IsEnabled="{Binding CanRevealTargetFolder}" Click="RevealTargetFolder_Click"><TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE890;" FontSize="14" /></Button><Button Margin="8,0,0,0" Style="{StaticResource BrowseButtonStyle}" ToolTip="选择文件夹" Click="ChooseFolder_Click"><TextBlock Text="..." /></Button></StackPanel></Grid><Border Grid.Row="2" Style="{StaticResource PathDisplayBorderStyle}" ToolTip="{Binding TargetFolderPath}"><TextBlock Text="{Binding TargetFolderPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" /></Border><Grid Grid.Row="3" Margin="0,8" Background="Transparent" Cursor="Hand" PreviewMouseLeftButtonUp="TargetFolderDropZone_PreviewMouseLeftButtonUp"><Rectangle Style="{StaticResource DropZoneDashStyle}" /><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" FontSize="58" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" /><TextBlock Margin="0,14,0,0" Text="+" FontSize="34" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" /></StackPanel></Grid></Grid>
                        </Border>
                        <Border x:Name="NewIconDropZone" Grid.Column="3" Padding="18" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDragEnter="DropZone_PreviewDragEnter" PreviewDragOver="DropZone_PreviewDragOver" PreviewDragLeave="DropZone_PreviewDragLeave" Drop="IconDropZone_Drop">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="10" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="请选择ICO图标" FontSize="16" FontWeight="SemiBold" /><Button Grid.Column="1" Style="{StaticResource BrowseButtonStyle}" ToolTip="选择 ICO" Click="ChooseIcon_Click"><TextBlock Text="..." /></Button></Grid><Border Grid.Row="2" Style="{StaticResource PathDisplayBorderStyle}" ToolTip="{Binding IconPath}"><TextBlock Text="{Binding IconPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" /></Border><Grid Grid.Row="3" Margin="0,8" Background="Transparent" Cursor="Hand" PreviewMouseLeftButtonUp="IconDropZone_PreviewMouseLeftButtonUp"><Rectangle Style="{StaticResource DropZoneDashStyle}" /><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEB9F;" FontSize="58" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" /><TextBlock Margin="0,14,0,0" Text="+" FontSize="34" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" /></StackPanel></Grid></Grid>
                        </Border>
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,48,0,0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><Button Style="{StaticResource PrimaryButtonStyle}" Content="立即应用" Command="{Binding ApplyCommand}" /><Button Margin="12,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Content="恢复默认" Command="{Binding RestoreCommand}" /></StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="2" Visibility="Collapsed" Orientation="Horizontal" HorizontalAlignment="Center"><Button Style="{StaticResource PrimaryButtonStyle}" Content="立即应用" Command="{Binding ApplyCommand}" /><Button Margin="16,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Content="恢复默认" Command="{Binding RestoreCommand}" /></StackPanel>
                    <Border Grid.Row="4" Width="560" MinHeight="44" HorizontalAlignment="Center" Padding="12,9" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"><TextBlock Text="{Binding StatusText}" ToolTip="{Binding StatusText}" FontSize="13" TextTrimming="CharacterEllipsis"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsStatusSuccess}" Value="True"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}" /></DataTrigger><DataTrigger Binding="{Binding IsStatusError}" Value="True"><Setter Property="Foreground" Value="{StaticResource ErrorBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Visibility="Collapsed">
        <Border Margin="18"
                Padding="22"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition x:Name="FavoritePanelRow" Height="1.35*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="TargetFolderDropZone"
                            Grid.Column="0"
                            Padding="18"
                            Background="{StaticResource DropZoneBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            AllowDrop="True"
                            PreviewDragEnter="DropZone_PreviewDragEnter"
                            PreviewDragOver="DropZone_PreviewDragOver"
                            PreviewDragLeave="DropZone_PreviewDragLeave"
                            Drop="TargetFolderDropZone_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="目标文件夹"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource BrowseButtonStyle}"
                                        ToolTip="选择文件夹"
                                        Click="ChooseFolder_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xE8B7;"
                                                   FontSize="15"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Margin="7,0,0,0"
                                                   Text="浏览"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     Style="{StaticResource PathTextBoxStyle}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding TargetFolderPath}"
                                     Text="{Binding TargetFolderPath, Mode=OneWay}" />

                            <StackPanel Grid.Row="3"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE8B7;"
                                           FontSize="58"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Margin="0,14,0,0"
                                           Text="+"
                                           FontSize="34"
                                           FontWeight="Light"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="IconDropZone"
                            Grid.Column="2"
                            Padding="18"
                            Background="{StaticResource DropZoneBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            AllowDrop="True"
                            PreviewDragEnter="DropZone_PreviewDragEnter"
                            PreviewDragOver="DropZone_PreviewDragOver"
                            PreviewDragLeave="DropZone_PreviewDragLeave"
                            Drop="IconDropZone_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ICO 图标"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource BrowseButtonStyle}"
                                        ToolTip="选择 ICO"
                                        Click="ChooseIcon_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xEB9F;"
                                                   FontSize="15"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Margin="7,0,0,0"
                                                   Text="浏览"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     Style="{StaticResource PathTextBoxStyle}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding IconPath}"
                                     Text="{Binding IconPath, Mode=OneWay}" />

                            <StackPanel Grid.Row="3"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xEB9F;"
                                           FontSize="58"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Margin="0,14,0,0"
                                           Text="+"
                                           FontSize="34"
                                           FontWeight="Light"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Content="立即应用"
                            Command="{Binding ApplyCommand}" />
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="恢复默认"
                            Command="{Binding RestoreCommand}" />
                </StackPanel>

                <Border x:Name="ArchivedFavoriteDropZone"
                        Grid.Row="4"
                        MinHeight="220"
                        Background="{StaticResource DropZoneBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        AllowDrop="True"
                        PreviewDragEnter="FavoriteDropZone_PreviewDragEnter"
                        PreviewDragOver="FavoriteDropZone_PreviewDragOver"
                        PreviewDragLeave="FavoriteDropZone_PreviewDragLeave"
                        Drop="FavoriteDropZone_Drop">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="图标收藏"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    ToolTip="添加收藏夹"
                                    Click="AddFavorite_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               Text="&#xE710;"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Margin="7,0,0,0"
                                               Text="添加收藏夹"
                                               VerticalAlignment="Center" />
                                    </StackPanel>
                            </Button>
                            <Button Grid.Column="4"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    ToolTip="展开或收起收藏区"
                                    Click="ToggleFavoritePanel_Click">
                                <TextBlock x:Name="FavoritePanelToggleIcon"
                                           FontFamily="Segoe Fluent Icons"
                                           Text="&#xE70D;"
                                           FontSize="14" />
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource BorderBrush}" />

                        <Grid x:Name="FavoritePanelContent" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>

                            <ListBox ItemsSource="{Binding FavoriteFolders}"
                                     SelectedItem="{Binding SelectedFavoriteFolder, Mode=OneWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,6">
                                            <Grid.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="从收藏夹移除"
                                                              CommandParameter="{Binding}"
                                                              Click="RemoveFavoriteFolder_Click" />
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontFamily="Segoe Fluent Icons"
                                                       Text="&#xE8B7;"
                                                       FontSize="18"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DisplayName}"
                                                       ToolTip="{Binding FolderPath}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Column="1"
                                    Background="{StaticResource BorderBrush}" />

                            <Grid Grid.Column="2" Margin="14,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedFavoriteFolder.DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FavoriteIconSummary}"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding FavoriteIcons}"
                                         SelectedItem="{Binding SelectedFavoriteIcon, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MouseDoubleClick="FavoriteIcons_MouseDoubleClick"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="106"
                                                    Height="116"
                                                    Margin="0,0,10,10"
                                                    Padding="10"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="24" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailPreview}"
                                                               Width="52"
                                                               Height="52"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                                   Text="&#xEB9F;"
                                                                   FontSize="36"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   IsHitTestVisible="False">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ThumbnailPreview}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding FileName}"
                                                               ToolTip="{Binding IconPath}"
                                                               FontSize="12"
                                                               VerticalAlignment="Bottom"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Border Grid.Column="3"
                                    Background="{StaticResource BorderBrush}" />

                            <Grid Grid.Column="4" Margin="14,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="原图预览"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />

                                <Border Grid.Row="2"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Image Source="{Binding SelectedFavoriteIcon.OriginalPreview}"
                                               MaxWidth="156"
                                               MaxHeight="156"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xEB9F;"
                                                   FontSize="48"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedFavoriteIcon.OriginalPreview}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <TextBlock Grid.Row="4"
                                           Text="{Binding SelectedFavoriteIcon.FileName, TargetNullValue=选择 ICO 图标}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="6"
                                           Text="{Binding SelectedFavoriteIcon.IconPath}"
                                           ToolTip="{Binding SelectedFavoriteIcon.IconPath}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="6"
                        MinHeight="44"
                        Padding="12,9"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="{Binding StatusText}"
                               ToolTip="{Binding StatusText}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
