<Window x:Class="FolderIconManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Icon Manager"
        Width="720"
        MinWidth="620"
        Height="540"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">
    <Grid Background="{StaticResource CanvasBrush}">
        <Border Margin="42"
                Padding="34"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Folder Icon Manager"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="选择一个非 C 盘文件夹和 ICO 图标，然后立即应用。"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="目标文件夹"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="0"
                             Style="{StaticResource PathTextBoxStyle}"
                             IsReadOnly="True"
                             Text="{Binding TargetFolderPath, Mode=OneWay}" />
                    <Button Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="选择文件夹"
                            Click="ChooseFolder_Click" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="ICO 图标"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="0"
                             Style="{StaticResource PathTextBoxStyle}"
                             IsReadOnly="True"
                             Text="{Binding IconPath, Mode=OneWay}" />
                    <Button Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="选择 ICO"
                            Click="ChooseIcon_Click" />
                </Grid>

                <StackPanel Grid.Row="6" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Content="立即应用"
                            Command="{Binding ApplyCommand}" />
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="恢复默认"
                            Command="{Binding RestoreCommand}" />
                </StackPanel>

                <Border Grid.Row="8"
                        Padding="12,10"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
