<Window x:Class="FolderIconManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Icon Manager"
        Width="1040"
        MinWidth="840"
        Height="720"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}">
    <Grid Background="{StaticResource CanvasBrush}">
        <Border Margin="18"
                Padding="22"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="TargetFolderDropZone"
                            Grid.Column="0"
                            Padding="18"
                            Background="{StaticResource DropZoneBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            AllowDrop="True"
                            PreviewDragEnter="DropZone_PreviewDragEnter"
                            PreviewDragOver="DropZone_PreviewDragOver"
                            PreviewDragLeave="DropZone_PreviewDragLeave"
                            Drop="TargetFolderDropZone_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="目标文件夹"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource BrowseButtonStyle}"
                                        ToolTip="选择文件夹"
                                        Click="ChooseFolder_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xE8B7;"
                                                   FontSize="15"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Margin="7,0,0,0"
                                                   Text="浏览"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     Style="{StaticResource PathTextBoxStyle}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding TargetFolderPath}"
                                     Text="{Binding TargetFolderPath, Mode=OneWay}" />

                            <StackPanel Grid.Row="3"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xE8B7;"
                                           FontSize="58"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Margin="0,14,0,0"
                                           Text="+"
                                           FontSize="34"
                                           FontWeight="Light"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="IconDropZone"
                            Grid.Column="2"
                            Padding="18"
                            Background="{StaticResource DropZoneBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            AllowDrop="True"
                            PreviewDragEnter="DropZone_PreviewDragEnter"
                            PreviewDragOver="DropZone_PreviewDragOver"
                            PreviewDragLeave="DropZone_PreviewDragLeave"
                            Drop="IconDropZone_Drop">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ICO 图标"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource BrowseButtonStyle}"
                                        ToolTip="选择 ICO"
                                        Click="ChooseIcon_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   Text="&#xEB9F;"
                                                   FontSize="15"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Margin="7,0,0,0"
                                                   Text="浏览"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     Style="{StaticResource PathTextBoxStyle}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding IconPath}"
                                     Text="{Binding IconPath, Mode=OneWay}" />

                            <StackPanel Grid.Row="3"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons"
                                           Text="&#xEB9F;"
                                           FontSize="58"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Margin="0,14,0,0"
                                           Text="+"
                                           FontSize="34"
                                           FontWeight="Light"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Content="立即应用"
                            Command="{Binding ApplyCommand}" />
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="恢复默认"
                            Command="{Binding RestoreCommand}" />
                </StackPanel>

                <Border Grid.Row="4"
                        MinHeight="44"
                        Padding="12,9"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="{Binding StatusText}"
                               ToolTip="{Binding StatusText}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
